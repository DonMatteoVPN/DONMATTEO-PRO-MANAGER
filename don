#!/bin/bash

# --- ТЕКУЩАЯ ВЕРСИЯ СКРИПТА ---
export APP_VERSION="02.233"
export REPO_RAW="https://raw.githubusercontent.com/DonMatteoVPN/DONMATTEO-PRO-MANAGER/main"

# Глобальные флаги (Инициализация)
export HAS_UPDATE="no"
export LATEST_VER=""
export UPDATE_AVAILABLE="false" 
export FAST_MIRROR=""
export DEBUG="false"

# Проверяем аргументы ДО set -u
for arg in "$@"; do 
    if [[ "$arg" == "--debug" ]]; then 
        export DEBUG="true"
        set -x  # Включаем трассировку команд
    fi
done

export OS_TYPE="linux"
[[ "$(uname)" == "Darwin" ]] && export OS_TYPE="macos"

# Включаем set -u только если НЕ debug режим
if [[ "$DEBUG" != "true" ]]; then
    set -u
fi

# Глобальные цвета
export RED='\033[0;31m'
export GREEN='\033[0;32m'
export YELLOW='\033[1;33m'
export BLUE='\033[0;34m'
export CYAN='\033[0;36m'
export MAGENTA='\033[0;35m'
export GRAY='\033[0;90m'
export NC='\033[0m'
export BOLD='\033[1m'

if [[ $EUID -ne 0 ]]; then echo -e "${RED}Запустите команду от имени root (sudo).${NC}"; exit 1; fi

# --- Поиск базового ядра ---
export BASE_DIR="/opt/remnawave/DONMATTEO-PRO-MANAGER"
export OLD_BASE="/opt/remnawave"

if [[ -f "${BASE_DIR}/modules/m_core.sh" ]]; then
    source "${BASE_DIR}/modules/m_core.sh"
elif [[ -f "${OLD_BASE}/modules/m_core.sh" ]]; then
    source "${OLD_BASE}/modules/m_core.sh"
else
    echo -e "${RED}[!] КРИТИЧЕСКАЯ ОШИБКА: Ядро m_core.sh не найдено.${NC}"
    exit 1
fi

# --- Миграция старых файлов (Один раз при запуске) ---
migrate_old_files

# --- Google DNS garanteed at startup (FIRST!) ---
ensure_google_dns

# --- Глобальные переменные путей (СТАНДАРТ v3) ---
TG_CONF=$(ensure_module_config "tg")
export TG_URL_FILE="${TG_CONF}/url.txt"
export TG_LISTS_FILE="${TG_CONF}/lists.txt"

F2B_CONF=$(ensure_module_config "f2b")
export WHITELIST_FILE="${F2B_CONF}/whitelist.txt"
export F2B_RETRY_FILE="${F2B_CONF}/maxretry.txt"
export F2B_FIND_FILE="${F2B_CONF}/findtime.txt"
export F2B_BAN_FILE="${F2B_CONF}/bantime.txt"

UFW_CONF=$(ensure_module_config "ufw")
export CONNLIMIT_FILE="${UFW_CONF}/limit_conn_ports.txt"
export RATELIMIT_FILE="${UFW_CONF}/limit_rate_ports.txt"
export CONN_VAL_FILE="${UFW_CONF}/limit_conn_val.txt"
export RATE_VAL_FILE="${UFW_CONF}/limit_rate_val.txt"

export MANUAL_FILE="${CONF_DIR}/tg/manual_ban.list"
export BANTIME="24h"

# ======================================================================
# --- ФУНКЦИИ СТАТУСОВ (По умолчанию) ---
# ======================================================================
get_sysctl_status() {
    if [[ "$(sysctl -n net.ipv4.tcp_syncookies 2>/dev/null)" == "1" ]]; then 
        echo -e "${GREEN}[ВКЛЮЧЕНО]${NC}"
    else 
        echo -e "${RED}[НЕ УСТАНОВЛЕНО]${NC}"
    fi
}

get_ufw_status() {
    if [[ "${OS_TYPE:-}" == "macos" ]]; then echo -e "${YELLOW}[N/A]${NC}"; return; fi
    if command -v ufw >/dev/null 2>&1; then
        if ufw status 2>/dev/null | grep -qw active; then echo -e "${GREEN}[РАБОТАЕТ]${NC}"; else echo -e "${YELLOW}[ВЫКЛЮЧЕН]${NC}"; fi
    else
        echo -e "${RED}[НЕ УСТАНОВЛЕН]${NC}"
    fi
}

get_f2b_status() {
    if [[ "${OS_TYPE:-}" == "macos" ]]; then echo -e "${YELLOW}[N/A]${NC}"; return; fi
    if command -v fail2ban-client >/dev/null 2>&1; then
        if systemctl is-active --quiet fail2ban 2>/dev/null; then 
            echo -e "${GREEN}[РАБОТАЕТ]${NC}"
        else 
            echo -e "${YELLOW}[ВКЛЮЧЕН/ОСТАНОВЛЕН]${NC}"
        fi
    else
        echo -e "${RED}[НЕ УСТАНОВЛЕН]${NC}"
    fi
}

get_tg_status() {
    if [[ "${OS_TYPE:-}" == "macos" ]]; then echo -e "${YELLOW}[N/A]${NC}"; return; fi
    if systemctl is-active --quiet antiscan-aggregate.timer 2>/dev/null; then 
        echo -e "${GREEN}[РАБОТАЕТ]${NC}"
    elif [[ -f /usr/local/bin/traffic-guard ]]; then 
        echo -e "${YELLOW}[УСТАНОВЛЕН, НО НЕ АКТИВЕН]${NC}"
    else 
        echo -e "${RED}[НЕ УСТАНОВЛЕНО]${NC}"
    fi
}

get_swap_status() {
    local swp=$(free -m 2>/dev/null | awk '/^Swap:/ {print $2}')
    local has_zram=$(lsblk 2>/dev/null | grep -i zram)
    local has_file=$(swapon --show --noheadings 2>/dev/null | grep -i "/swapfile")
    
    if [[ -n "$has_zram" && -n "$has_file" ]]; then echo -e "${GREEN}[ГИБРИД: ZRAM + Swap]${NC}"
    elif [[ -n "$has_zram" ]]; then echo -e "${GREEN}[ZRAM ВКЛЮЧЕН]${NC}"
    elif [[ "$swp" != "0" && -n "$swp" ]]; then echo -e "${YELLOW}[DISK SWAP: ${swp} MB]${NC}"
    else echo -e "${RED}[ВЫКЛЮЧЕН]${NC}"; fi
}

get_ssh_status() {
    if [[ "${OS_TYPE:-}" == "macos" ]]; then echo -e "${YELLOW}[N/A]${NC}"; return; fi
    local status_text
    if systemctl is-active --quiet ssh 2>/dev/null || systemctl is-active --quiet sshd 2>/dev/null; then status_text="${GREEN}[РАБОТАЕТ]${NC}"; else status_text="${RED}[ВЫКЛЮЧЕН]${NC}"; fi
    local ports=$(grep -i "^Port " /etc/ssh/sshd_config | awk '{print $2}' | xargs | sed 's/ /, /g')
    [[ -z "$ports" ]] && ports="22"
    echo -e "${status_text} ${GRAY}(Порты: ${ports})${NC}"
}

get_node_status() {
    if crontab -l 2>/dev/null | grep -q "update_assets.sh"; then
        echo -e "${GREEN}[Автообновление: ВКЛ]${NC}"
    else
        echo -e "${GRAY}[Автообновление: ВЫКЛ]${NC}"
    fi
}

# --- Динамическая загрузка модулей ---
load_modules() {
    if [[ -f "$MOD_LIST_FILE" ]]; then
        while read -r mod; do
            [[ -z "$mod" || "$mod" == "m_core.sh" ]] && continue
            if [[ -f "${MOD_DIR}/${mod}" ]]; then
                source "${MOD_DIR}/${mod}" || echo -e "${RED}[!] Ошибка в модуле ${mod}${NC}"
            fi
        done < "$MOD_LIST_FILE"
    else
        for mod_path in "${MOD_DIR}"/m_*.sh; do
            mod=$(basename "$mod_path")
            [[ "$mod" == "m_core.sh" ]] && continue
            source "$mod_path"
        done
    fi
}
load_modules

# --- Инициализация сети ---
find_fastest_mirror

if [[ "${1:-}" == "--silent-clean" ]]; then silent_cleaner_run; exit 0; fi

trap 'echo -e "\n${YELLOW}Возврат...${NC}"; sleep 1; return 2>/dev/null || exit 0' INT

pause() { echo -e "\n${CYAN}Нажмите [Enter] для возврата...${NC}"; read -r < /dev/tty; }
export -f pause

show_banner() {
    echo -e "${CYAN}======================================================${NC}"
    echo -e "${MAGENTA}${BOLD} ____              __  __       _   _             ${NC}"
    echo -e "${MAGENTA}${BOLD}|  _ \\  ___  _ __ |  \\/  | __ _| |_| |_ ___  ___  ${NC}"
    echo -e "${MAGENTA}${BOLD}| | | |/ _ \\| '_ \\| |\\/| |/ _\` | __| __/ _ \\/ _ \\ ${NC}"
    echo -e "${MAGENTA}${BOLD}| |_| | (_) | | | | |  | | (_| | |_| ||  __/ (_) |${NC}"
    echo -e "${MAGENTA}${BOLD}|____/ \\___/|_| |_|_|  |_|\\__,_|\\__|\\__\\___|\\___/ ${NC}"
    echo -e "                                                      "
    echo -e "${RED}${BOLD}              ОТ РЕШАЛЫ С ЛЮБОВЬЮ БЛЯТЬ         ${NC}"
    echo -e "${CYAN}======================================================${NC}"
    echo -e " ${GRAY}Версия ядра: v${APP_VERSION} (PRO)${NC}"
    echo -e "${CYAN}======================================================${NC}"
}

check_updates() {
    # Сбрасываем кэш обновлений при каждом возврате в меню
    smart_dns_fix
    
    local TS=$(date +%s)
    local RAND=$(( RANDOM % 9999 ))
    local NANO=$(date +%N 2>/dev/null || echo $RANDOM)
    local BUSTER="t=${TS}&r=${RAND}&n=${NANO}"
    local TEMP_VER="/tmp/ver_check_${TS}.txt"
    local REMOTE_VERSION=""
    
    local COMMIT_SHA=$(curl -fsSL --connect-timeout 2 --max-time 3 \
        -H "Cache-Control: no-cache, no-store, must-revalidate" \
        -H "Pragma: no-cache" \
        -H "Expires: 0" \
        "https://api.github.com/repos/DonMatteoVPN/DONMATTEO-PRO-MANAGER/commits/main" 2>/dev/null | \
        grep -oP '"sha":\s*"\K[^"]+' | head -n1)
    
    if [[ -n "$COMMIT_SHA" && ${#COMMIT_SHA} -eq 40 ]]; then
        local COMMIT_URL="https://raw.githubusercontent.com/DonMatteoVPN/DONMATTEO-PRO-MANAGER/${COMMIT_SHA}/don"
        if curl -fsSL --connect-timeout 2 --max-time 5 \
            -H "Cache-Control: no-cache, no-store, must-revalidate" \
            -H "Pragma: no-cache" \
            "$COMMIT_URL" -o "$TEMP_VER" 2>/dev/null; then
            REMOTE_VERSION=$(grep '^export APP_VERSION=' "$TEMP_VER" | head -n 1 | cut -d'"' -f2 | tr -d '\r\n ')
        fi
    fi
    
    if [[ -z "$REMOTE_VERSION" ]]; then
        local RAW_URL="https://raw.githubusercontent.com/DonMatteoVPN/DONMATTEO-PRO-MANAGER/main/don?${BUSTER}"
        if curl -fsSL --connect-timeout 2 --max-time 5 \
            -H "Cache-Control: no-cache, no-store, must-revalidate" \
            -H "Pragma: no-cache" \
            -H "Expires: 0" \
            "$RAW_URL" -o "$TEMP_VER" 2>/dev/null; then
            REMOTE_VERSION=$(grep '^export APP_VERSION=' "$TEMP_VER" | head -n 1 | cut -d'"' -f2 | tr -d '\r\n ')
        fi
    fi

    if [[ -z "$REMOTE_VERSION" ]]; then
        curl -fsSL --connect-timeout 1 --max-time 2 \
            "https://purge.jsdelivr.net/gh/DonMatteoVPN/DONMATTEO-PRO-MANAGER@main/don" >/dev/null 2>&1
        
        local JSD_URL="https://cdn.jsdelivr.net/gh/DonMatteoVPN/DONMATTEO-PRO-MANAGER@main/don?${BUSTER}"
        if curl -fsSL --connect-timeout 2 --max-time 5 \
            -H "Cache-Control: no-cache" \
            "$JSD_URL" -o "$TEMP_VER" 2>/dev/null; then
            REMOTE_VERSION=$(grep '^export APP_VERSION=' "$TEMP_VER" | head -n 1 | cut -d'"' -f2 | tr -d '\r\n ')
        fi
    fi
    
    rm -f "$TEMP_VER"

    if [[ -n "$REMOTE_VERSION" && "$REMOTE_VERSION" != "$APP_VERSION" ]]; then
        if version_gt "$REMOTE_VERSION" "$APP_VERSION"; then
            export HAS_UPDATE="yes"
            export LATEST_VER="$REMOTE_VERSION"
            export UPDATE_AVAILABLE="true"
        else
            export HAS_UPDATE="no"
            export LATEST_VER=""
            export UPDATE_AVAILABLE="false"
        fi
    else
        export HAS_UPDATE="no"
        export LATEST_VER=""
        export UPDATE_AVAILABLE="false"
    fi
}

main_menu() {
    if [[ "${DEBUG:-false}" == "true" ]]; then
        echo -e "${YELLOW}${BOLD}[ DEBUG MODE: ON ]${NC}"
        echo -e "${GRAY}Все сообщения об ошибках и детальный вывод команд включены.${NC}\n"
    fi

    check_updates

    while true; do
        clear; show_banner
        if [[ "${HAS_UPDATE:-no}" == "yes" ]]; then
            echo -e "${YELLOW}${BOLD}🎉 ВНИМАНИЕ! ДОСТУПНО НОВОЕ ОБНОВЛЕНИЕ МЕНЕДЖЕРА! 🎉${NC}"
            echo -e "${GREEN}✨ Вышла новая версия: v${LATEST_VER:-?}${NC} (У вас v${APP_VERSION})"
            echo -e "${CYAN}👉 Нажмите [8], чтобы обновиться в один клик!${NC}"
            echo -e "${YELLOW}======================================================${NC}"
        fi
        echo -e " ${GREEN}U.${NC} 🛠️ УСТАНОВКА И ИНИЦИАЛИЗАЦИЯ ${BLUE}(Sysctl + UFW + Fail2Ban)${NC}"
        echo -e " ${GREEN}R.${NC} 🔍 Reality TLS Scanner"
        echo -e " ${GREEN}N.${NC} 🛰️ Управление Нодой $(get_node_status)"
        echo -e "${BLUE}------------------------------------------------------${NC}"
        echo -e " ${YELLOW}1.${NC} 🌐 Сетевой Экран (UFW)\e[40G${NC}$(get_ufw_status)"
        echo -e " ${YELLOW}2.${NC} 🔑 Управление SSH (Порты)\e[40G${NC}$(get_ssh_status)"
        echo -e " ${YELLOW}3.${NC} 👮 Защита (Fail2Ban & Whitelist)\e[40G${NC}$(get_f2b_status)"
        echo -e " ${YELLOW}4.${NC} 🚦 TrafficGuard PRO\e[40G${NC}$(get_tg_status)"
        echo -e " ${YELLOW}5.${NC} ⚙️ Настройки (Swap / ZRAM)\e[40G${NC}$(get_swap_status)"
        echo -e " ${YELLOW}6.${NC} 🧹 Очистка Сервера (Место на диске)"
        if [[ "${HAS_UPDATE:-no}" == "yes" ]]; then
            echo -e "${BLUE}------------------------------------------------------${NC}"
            echo -e " ${GREEN}8.${NC} 🎁 ${BOLD}СКАЧАТЬ ОБНОВЛЕНИЕ ДО v${LATEST_VER:-?}${NC}"
        fi
        echo -e " ${RED}0.${NC} ❌ Выход                             "
        echo -e "${CYAN}======================================================${NC}"
        read -p "Выберите нужную категорию: " choice
        case $choice in
            u|U) install_menu; check_updates ;; 
            r|R) menu_scanner; check_updates ;; 
            n|N) menu_node; check_updates ;;
            1) menu_ufw; check_updates ;; 
            2) menu_ssh; check_updates ;; 
            3) menu_fail2ban; check_updates ;; 
            4) menu_trafficguard; check_updates ;;
            5) manage_swap; check_updates ;; 
            6) menu_cleaner; check_updates ;;
            8) [[ "$HAS_UPDATE" == "yes" ]] && run_auto_update "$@" || { echo -e "${RED}Обновлений нет.${NC}"; sleep 1; } ;;
            0) echo -e "${GREEN}Удачной работы! 💪${NC}"; exit 0 ;;
            *) echo -e "${RED}Ошибка: Неверный выбор.${NC}"; sleep 1 ;;
        esac
    done
}

main_menu "$@"
