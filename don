#!/bin/bash
# =============================================================================
# DONMATTEO PRO MANAGER — Главный управляющий файл
# =============================================================================
# Версия: 03.000 (Полностью переписан — Единый Стандарт 2026)
#
# ДЛЯ ЧАЙНИКОВ: Это главный файл менеджера сервера. Когда ты вводишь
# команду "don" в терминале, запускается именно этот файл. Он загружает
# все нужные модули и показывает тебе главное меню с пунктами управления.
#
# Как это работает:
#   1. Проверяет что ты root (иначе ничего не будет работать)
#   2. Загружает "ядро" — базовые функции из modules/core/
#   3. Загружает все остальные модули в правильном порядке
#   4. Показывает красивое главное меню
#
# Как добавить свой модуль:
#   Создай файл m_*.sh в папке modules/ (НЕ в modules/core/)
#   Менеджер автоматически его найдёт при следующем запуске!
# =============================================================================

export DON_VERSION="03.000"

# =============================================================================
# АРГУМЕНТЫ КОМАНДНОЙ СТРОКИ
# =============================================================================
export DEBUG="false"
for arg in "$@"; do
    case "$arg" in
        --debug)        export DEBUG="true"; set -x ;;
        --silent-clean) DO_SILENT_CLEAN="true" ;;
        --version)      echo "DONMATTEO PRO MANAGER v${DON_VERSION}"; exit 0 ;;
        --help)
            echo "Использование: don [--debug] [--silent-clean] [--version]"
            echo "  --debug         Режим трассировки команд"
            echo "  --silent-clean  Тихая автоочистка (для cron)"
            echo "  --version       Показать версию"
            exit 0 ;;
    esac
done

# =============================================================================
# ОПРЕДЕЛЕНИЕ СИСТЕМЫ
# =============================================================================
export OS_TYPE="linux"
[[ "$(uname)" == "Darwin" ]] && export OS_TYPE="macos"

# Проверка прав root
if [[ $EUID -ne 0 ]]; then
    echo -e "\033[0;31m[!] Ошибка: Запустите от имени root: sudo don\033[0m"
    exit 1
fi

# =============================================================================
# ЦВЕТА (единый стиль — не меняй без необходимости)
# =============================================================================
export RED='\033[0;31m'     # Ошибки, опасные действия
export GREEN='\033[0;32m'   # Успех, включено
export YELLOW='\033[1;33m'  # Предупреждения
export BLUE='\033[0;34m'    # Рамки, разделители
export CYAN='\033[0;36m'    # Информация, процессы
export MAGENTA='\033[0;35m' # Заголовки, акценты
export GRAY='\033[0;90m'    # Пояснения, вторичный текст
export NC='\033[0m'         # Сброс цвета
export BOLD='\033[1m'       # Жирный текст

# =============================================================================
# ЗАГРУЗКА ЯДРА (m_00_core.sh — обязателен!)
# =============================================================================
# ДЛЯ ЧАЙНИКОВ: Ядро — это самый важный файл. Без него ничего не работает.
# Ищем его в нескольких местах на случай первого запуска или обновления.

# 1. Устанавливаем пути (do загрузки ядра)
export BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export CONF_DIR="${BASE_DIR}/etc"
export MOD_DIR="${BASE_DIR}/modules"
export CORE_DIR="${MOD_DIR}/core"
export AUDIT_LOG="/var/log/don_audit.log"

# 2. Ищем ядро
CORE_FILE="${CORE_DIR}/m_00_core.sh"

if [[ ! -f "$CORE_FILE" ]]; then
    # Fallback: ищем в старых местах (для совместимости при обновлении)
    for fallback in \
        "${MOD_DIR}/m_core.sh" \
        "/opt/remnawave/modules/m_core.sh"; do
        if [[ -f "$fallback" ]]; then
            CORE_FILE="$fallback"
            echo -e "\033[1;33m[!] Ядро найдено в устаревшем месте: ${fallback}\033[0m"
            echo -e "\033[1;33m    Запусти: bash install.sh для коррекной установки\033[0m"
            break
        fi
    done
fi

if [[ ! -f "$CORE_FILE" ]]; then
    echo -e "\033[0;31m[!] КРИТИЧЕСКАЯ ОШИБКА: Файл ядра не найден!\033[0m"
    echo -e "\033[1;33m    Переустановите менеджер: bash install.sh\033[0m"
    exit 1
fi

# shellcheck source=modules/core/m_00_core.sh
source "$CORE_FILE"

# =============================================================================
# АВТОМАТИЧЕСКАЯ ЗАГРУЗКА ВСЕХ МОДУЛЕЙ (БАГ #17 FIX — авто-обнаружение)
# =============================================================================
# ДЛЯ ЧАЙНИКОВ: Менеджер сам находит все модули в папке modules/core/
# в правильном порядке (по числовому префиксу: m_00_, m_10_, m_20_ и т.д.)
# Если ты добавишь свой модуль в modules/ — он тоже загрузится автоматически!

load_modules() {
    local loaded=0
    local failed=()

    # --- 1. Core-модули в числовом порядке (m_00_core уже загружен выше) ---
    while IFS= read -r -d '' mod_path; do
        # Пропускаем уже загруженное ядро
        [[ "$mod_path" == "$CORE_FILE" ]] && continue
        [[ ! -f "$mod_path" ]] && continue

        if source "$mod_path"; then
            ((loaded++))
            [[ "$DEBUG" == "true" ]] && echo -e "${GRAY}[DEBUG] Загружен: ${mod_path}${NC}" >&2
        else
            failed+=("$(basename "$mod_path")")
        fi
    done < <(find "$CORE_DIR" -maxdepth 1 -name 'm_[0-9][0-9]_*.sh' -print0 2>/dev/null | sort -z)

    # --- 2. Пользовательские модули (прямо в modules/, НЕ в core/) ---
    while IFS= read -r -d '' mod_path; do
        [[ ! -f "$mod_path" ]] && continue
        # shellcheck source=/dev/null
        if source "$mod_path"; then
            ((loaded++))
            [[ "$DEBUG" == "true" ]] && echo -e "${GRAY}[DEBUG] Польз. модуль: ${mod_path}${NC}" >&2
        else
            failed+=("[user] $(basename "$mod_path")")
        fi
    done < <(find "$MOD_DIR" -maxdepth 1 -name 'm_*.sh' -print0 2>/dev/null | sort -z)

    if [[ ${#failed[@]} -gt 0 ]]; then
        echo -e "${YELLOW}[!] Не удалось загрузить модули: ${failed[*]}${NC}"
    fi

    [[ "$DEBUG" == "true" ]] && echo -e "${GRAY}[DEBUG] Загружено модулей: ${loaded}${NC}"
}

# =============================================================================
# ИНИЦИАЛИЗАЦИЯ
# =============================================================================
migrate_old_files          # Переносим файлы из старых мест (один раз)
load_settings 2>/dev/null  # Загружаем настройки (из m_20_config.sh)
ensure_google_dns          # Стабильный DNS для работы с сетью
load_modules               # Загружаем все модули

# Восстанавливаем DNS при выходе из скрипта (по любой причине)
trap 'restore_dns 2>/dev/null || true' EXIT

# =============================================================================
# ТИХАЯ ОЧИСТКА (для cron: don --silent-clean)
# =============================================================================
if [[ "${DO_SILENT_CLEAN:-false}" == "true" ]]; then
    silent_cleaner_run 2>/dev/null || true
    exit 0
fi

# =============================================================================
# ПРОВЕРКА ЗАВИСИМОСТЕЙ (БАГ #17 FIX)
# =============================================================================
dep_check "python3" "curl" "awk" "grep" "sed" >/dev/null 2>&1

# =============================================================================
# ПРОВЕРКА ОБНОВЛЕНИЙ (не блокирует запуск, тихо в фоне)
# =============================================================================
check_update_on_start 2>/dev/null &

# =============================================================================
# ГЛАВНОЕ МЕНЮ
# =============================================================================
main_menu() {
    while true; do
        clear

        # === ШАПКА ===
        echo -e "${BLUE}╔══════════════════════════════════════════════════════╗${NC}"
        echo -e "${BLUE}║${NC}  ${BOLD}${MAGENTA}🛡️  DONMATTEO PRO MANAGER${NC}  ${GRAY}v${DON_VERSION}${NC}${BLUE}                  ║${NC}"
        echo -e "${BLUE}╚══════════════════════════════════════════════════════╝${NC}"
        show_system_info 2>/dev/null
        echo ""

        # === СТАТУСЫ ЗАЩИТЫ ===
        echo -e " ${BOLD}ЗАЩИТА СЕРВЕРА:${NC}"
        echo -e "  🔒 UFW:       $(get_ufw_status)   🔐 F2B: $(get_f2b_status)"
        echo -e "  🛡️  TGuard:   $(get_tg_status 2>/dev/null || echo '...')   ⚙️  SYS: $(get_sysctl_status)"
        echo -e "  💾 Memory:   $(get_swap_status)"
        echo ""

        # === ПУНКТЫ МЕНЮ ===
        echo -e " ${BOLD}БЕЗОПАСНОСТЬ:${NC}"
        echo -e "  ${GREEN}1.${NC} 🔒 Файервол (UFW)"
        echo -e "  ${GREEN}2.${NC} 🔐 Fail2Ban — Защита от взломщиков"
        echo -e "  ${GREEN}3.${NC} 🛡️  TrafficGuard — Блокировка сканеров"
        echo -e "  ${GREEN}4.${NC} 🔑 SSH-порты"
        echo ""

        echo -e " ${BOLD}УПРАВЛЕНИЕ СЕРВЕРОМ:${NC}"
        echo -e "  ${CYAN}5.${NC} 🧹 Очистка (место на диске)"
        echo -e "  ${CYAN}6.${NC} 💾 Память (ZRAM + Swap)"
        echo -e "  ${CYAN}7.${NC} 🛰️  Нода (Xray Assets / Логи)"
        echo -e "  ${CYAN}8.${NC} 🔍 TLS-Scanner (Поиск SNI)"
        echo ""

        echo -e " ${BOLD}УСТАНОВКА И СИСТЕМА:${NC}"
        echo -e "  ${YELLOW}9.${NC} 🚀 Установить Золотой Стандарт 2026"
        echo -e "  ${YELLOW}U.${NC} 🔄 Обновить менеджер $(get_config_status 2>/dev/null)"
        echo -e "  ${YELLOW}C.${NC} ⚙️  Настройки менеджера"
        echo ""

        echo -e " ${BOLD}ПРОЧЕЕ:${NC}"
        echo -e "  ${GRAY}0.${NC} 🚪 Выход"

        echo -e "${BLUE}══════════════════════════════════════════════════════${NC}"
        read -rp ">> Выберите действие: " choice < /dev/tty

        case "${choice,,}" in
            1) menu_ufw 2>/dev/null || echo -e "${RED}Модуль UFW недоступен.${NC}" ;;
            2) menu_f2b 2>/dev/null || echo -e "${RED}Модуль Fail2Ban недоступен.${NC}" ;;
            3) menu_tg 2>/dev/null  || echo -e "${RED}Модуль TGuard недоступен.${NC}" ;;
            4) menu_ssh 2>/dev/null || echo -e "${RED}Модуль SSH недоступен.${NC}" ;;
            5) menu_cleaner 2>/dev/null || echo -e "${RED}Модуль Cleaner недоступен.${NC}" ;;
            6) menu_swap 2>/dev/null    || echo -e "${RED}Модуль Swap недоступен.${NC}" ;;
            7) menu_node 2>/dev/null    || echo -e "${RED}Модуль Node недоступен.${NC}" ;;
            8) menu_scanner 2>/dev/null || echo -e "${RED}Модуль Scanner недоступен.${NC}" ;;
            9) menu_installer 2>/dev/null || echo -e "${RED}Модуль Installer недоступен.${NC}" ;;
            u) menu_update 2>/dev/null  || echo -e "${RED}Модуль Update недоступен.${NC}" ;;
            c) menu_config 2>/dev/null  || echo -e "${RED}Модуль Config недоступен.${NC}" ;;
            0|q|exit|quit)
                echo -e "${GREEN}До свидания!${NC}"
                exit 0 ;;
            *)
                # Проверяем не является ли это числовым выбором для пользовательского модуля
                echo -e "${YELLOW}[!] Неизвестная команда: '${choice}'.${NC}"
                sleep 1 ;;
        esac
    done
}

# Запускаем главное меню
main_menu
