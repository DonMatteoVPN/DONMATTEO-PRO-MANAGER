#!/bin/bash
set -u

# --- ТЕКУЩАЯ ВЕРСИЯ СКРИПТА ---
export APP_VERSION="01.030"
export REPO_RAW="https://raw.githubusercontent.com/DonMatteoVPN/DONMATTEO-PRO-MANAGER/main"

# Глобальные цвета
export RED='\033[0;31m'
export GREEN='\033[0;32m'
export YELLOW='\033[1;33m'
export BLUE='\033[0;34m'
export CYAN='\033[0;36m'
export MAGENTA='\033[0;35m'
export GRAY='\033[0;90m'
export NC='\033[0m'
export BOLD='\033[1m'

# Глобальные переменные путей
export WHITELIST_FILE="/opt/remnawave/whitelist.txt"
export CONNLIMIT_FILE="/opt/remnawave/limit_conn.txt"
export RATELIMIT_FILE="/opt/remnawave/limit_rate.txt"
export TG_URL_FILE="/opt/remnawave/tg_url.txt"
export TG_LISTS_FILE="/opt/remnawave/tg_lists.txt"
export MANUAL_FILE="/opt/trafficguard-manual.list"
export BANTIME="24h"
export MOD_DIR="/opt/remnawave/modules"

if [[ $EUID -ne 0 ]]; then echo -e "${RED}Запустите команду от имени root (sudo).${NC}"; exit 1; fi

# --- Загрузка модулей (Бронебойная) ---
for mod in m_ufw m_ssh m_f2b m_tg m_swap m_cleaner m_installer m_update m_scanner; do
    if [[ -f "${MOD_DIR}/${mod}.sh" ]]; then
        source "${MOD_DIR}/${mod}.sh" || echo -e "${RED}[!] Ошибка в коде модуля ${mod}${NC}"
    else
        # Вместо exit 1 просто выводим предупреждение
        echo -e "${YELLOW}[⚠️] Модуль ${mod} временно недоступен (не найден)${NC}"
        # Создаем пустую функцию-заглушку, чтобы меню не падало при вызове
        eval "menu_${mod/m_/}(){ echo -e '${RED}Ошибка: Модуль ${mod} не загружен. Обновите менеджер через пункт 8.${NC}'; pause; }"
    fi
done
sleep 1 # Даем время увидеть, если что-то не загрузилось

if [[ "${1:-}" == "--silent-clean" ]]; then silent_cleaner_run; exit 0; fi

trap 'echo -e "\n${YELLOW}Возврат...${NC}"; sleep 1; return 2>/dev/null || exit 0' INT

pause() { echo -e "\n${CYAN}Нажмите [Enter] для возврата...${NC}"; read -r < /dev/tty; }
export -f pause

# ======================================================================
# --- ФУНКЦИИ СТАТУСОВ (БРОНЕБОЙНЫЕ) ---
# ======================================================================
get_sysctl_status() {
    if [[ "$(sysctl -n net.ipv4.tcp_syncookies 2>/dev/null)" == "1" ]]; then echo -e "${GREEN}[ВКЛЮЧЕНО]${NC}"; else echo -e "${RED}[НЕ УСТАНОВЛЕНО]${NC}"; fi
}
get_ufw_status() {
    if ufw status 2>/dev/null | grep -qw active; then echo -e "${GREEN}[РАБОТАЕТ]${NC}"; else echo -e "${RED}[ВЫКЛЮЧЕН]${NC}"; fi
}
get_f2b_status() {
    if systemctl is-active --quiet fail2ban; then echo -e "${GREEN}[РАБОТАЕТ]${NC}"; else echo -e "${RED}[НЕ УСТАНОВЛЕНО/ВЫКЛЮЧЕН]${NC}"; fi
}
get_tg_status() {
    if systemctl is-active --quiet antiscan-aggregate.timer; then echo -e "${GREEN}[РАБОТАЕТ]${NC}"; elif [[ -f /usr/local/bin/traffic-guard ]]; then echo -e "${YELLOW}[УСТАНОВЛЕН, НО НЕ АКТИВЕН]${NC}"; else echo -e "${RED}[НЕ УСТАНОВЛЕНО]${NC}"; fi
}
get_swap_status() {
    local swp=$(free -m 2>/dev/null | awk '/^Swap:/ {print $2}')
    if [[ "$swp" != "0" && -n "$swp" ]]; then echo -e "${GREEN}[ВКЛЮЧЕНО: ${swp} MB]${NC}"; else echo -e "${RED}[ВЫКЛЮЧЕН]${NC}"; fi
}

show_banner() {
    echo -e "${CYAN}======================================================${NC}"
    echo -e "${MAGENTA}${BOLD} ____              __  __       _   _             ${NC}"
    echo -e "${MAGENTA}${BOLD}|  _ \\  ___  _ __ |  \\/  | __ _| |_| |_ ___  ___  ${NC}"
    echo -e "${MAGENTA}${BOLD}| | | |/ _ \\| '_ \\| |\\/| |/ _\` | __| __/ _ \\/ _ \\ ${NC}"
    echo -e "${MAGENTA}${BOLD}| |_| | (_) | | | | |  | | (_| | |_| ||  __/ (_) |${NC}"
    echo -e "${MAGENTA}${BOLD}|____/ \\___/|_| |_|_|  |_|\\__,_|\\__|\\__\\___|\\___/ ${NC}"
    echo -e "                                                      "
    echo -e "${RED}${BOLD}                 С ЛЮБОВЬЮ БЛЯТЬ                 ${NC}"
    echo -e "${CYAN}======================================================${NC}"
    echo -e " ${GRAY}Версия ядра: v${APP_VERSION}${NC}"
    echo -e "${CYAN}======================================================${NC}"
}

# --- ПРОВЕРКА ОБНОВЛЕНИЙ (БЕЗ КЭША) ---
check_updates() {
    local API_URL="https://api.github.com/repos/DonMatteoVPN/DONMATTEO-PRO-MANAGER/contents/don"
    REMOTE_VERSION=$(curl -s --max-time 3 -H "Accept: application/vnd.github.v3.raw" "$API_URL" | grep -m 1 '^export APP_VERSION=' | cut -d'"' -f2 | tr -d '\r\n ')
    
    if [[ -z "$REMOTE_VERSION" || ! "$REMOTE_VERSION" =~ ^[0-9]+\.[0-9]+$ ]]; then
        REMOTE_VERSION=$(curl -s --max-time 3 "${REPO_RAW}/don" | grep -m 1 '^export APP_VERSION=' | cut -d'"' -f2 | tr -d '\r\n ')
    fi
    
    if [[ -n "$REMOTE_VERSION" && "$REMOTE_VERSION" != "$APP_VERSION" && "$REMOTE_VERSION" =~ ^[0-9]+\.[0-9]+$ ]]; then
        export HAS_UPDATE="yes"
        export LATEST_VER="$REMOTE_VERSION"
    else
        export HAS_UPDATE="no"
    fi
}

main_menu() {
    while true; do
        check_updates 
        clear; show_banner
        
        if [[ "$HAS_UPDATE" == "yes" ]]; then
            echo -e "${YELLOW}${BOLD}🎉 ВНИМАНИЕ! ДОСТУПНО НОВОЕ ОБНОВЛЕНИЕ МЕНЕДЖЕРА! 🎉${NC}"
            echo -e "${GREEN}✨ Вышла новая версия: v${LATEST_VER}${NC} (У вас v${APP_VERSION})"
            echo -e "${CYAN}👉 Нажмите [8], чтобы обновиться в один клик!${NC}"
            echo -e "${YELLOW}======================================================${NC}"
        fi

        echo -e " ${GREEN}U.${NC} 🛠️  УСТАНОВКА И ИНИЦИАЛИЗАЦИЯ        "
        echo -e " ${GREEN}R.${NC} 🔍 Reality TLS Scanner               ${GRAY}(Поиск маскировки)${NC}"
        echo -e "${BLUE}------------------------------------------------------${NC}"
        echo -e " ${YELLOW}1.${NC} 🌐 Сетевой Экран (UFW)               ${NC}$(get_ufw_status)"
        echo -e " ${YELLOW}2.${NC} 🔑 Управление SSH (Порты)            "
        echo -e " ${YELLOW}3.${NC} 👮 Защита (Fail2Ban & Whitelist)     ${NC}$(get_f2b_status)"
        echo -e " ${YELLOW}4.${NC} 🚦 TrafficGuard PRO                  ${NC}$(get_tg_status)"
        echo -e " ${YELLOW}5.${NC} ⚙️  Настройки (Swap / Память)        ${NC}$(get_swap_status)"
        echo -e " ${YELLOW}6.${NC} 🧹 Очистка Сервера (Место на диске)  "
        
        if [[ "$HAS_UPDATE" == "yes" ]]; then
            echo -e "${BLUE}------------------------------------------------------${NC}"
            echo -e " ${GREEN}8.${NC} 🎁 ${BOLD}СКАЧАТЬ ОБНОВЛЕНИЕ ДО v${LATEST_VER}${NC}"
        fi
        
        echo -e " ${RED}0.${NC} ❌ Выход                             "
        echo -e "${CYAN}======================================================${NC}"
        read -p "Выберите нужную категорию: " choice
        
        case $choice in
            u|U) install_menu ;;
            r|R) menu_scanner ;;
            1) menu_ufw ;; 
            2) menu_ssh ;; 
            3) menu_fail2ban ;; 
            4) menu_trafficguard ;;
            5) manage_swap ;; 
            6) menu_cleaner ;;
            8) [[ "$HAS_UPDATE" == "yes" ]] && run_auto_update || echo -e "${RED}Обновлений нет.${NC}"; sleep 1 ;;
            0) echo -e "${GREEN}Удачной работы! До связи! 💪${NC}"; exit 0 ;;
            *) echo -e "${RED}Ошибка: Неверный выбор.${NC}"; sleep 1 ;;
        esac
    done
}

main_menu
